{
  "name": "react-page-and-form-builder",
  "version": "0.1.4",
  "description": "UI-agnostic React page-builder component with 12-column grid, section/component picker, and full render-prop overrides.",
  "author": "Akil Momin",
  "license": "MIT",
  "keywords": [
    "react",
    "page-builder",
    "drag-drop",
    "grid",
    "layout",
    "cms",
    "component-library"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akilmomin/New-Page-Builder-App.git",
    "directory": "packages/page-builder-core"
  },
  "homepage": "https://github.com/akilmomin/New-Page-Builder-App/tree/main/packages/page-builder-core#readme",
  "bugs": {
    "url": "https://github.com/akilmomin/New-Page-Builder-App/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles": "./src/styles/base.css"
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:coverage": "jest --config jest.config.cjs --coverage"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
